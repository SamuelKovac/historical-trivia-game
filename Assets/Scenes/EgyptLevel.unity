  m_Script: {fileID: 11500000, guid: e37892936168b5742b6b52efb089d3f5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  Collectible: {fileID: 237620098}
  textUvod: "Ahoj cestovate\u013E! Ja som fara\xF3n Tutancham\xF3n. V\xEDtam \u0165a
    v mojom chr\xE1me"
  textPrechod: "Vid\xEDm, \u017Ee h\u013Ead\xE1\u0161 vedomosti star\xE9ho Egypta.
    Polo\u017E\xEDm ti p\xE1r ot\xE1zok na preverenie tvojej mysle"
  casZobrazeniaTextu: 3.5
  textOtazky: "Ktor\xE1 rieka bola pre starovek\xFD Egypt najd\xF4le\u017Eitej\u0161ia,
    preto\u017Ee prin\xE1\u0161ala z\xE1plavy a \xFArodn\xFA p\xF4du?"
  odpovedA: "Rieka N\xEDl"
  odpovedB: Rieka Eufrat
  indexSpravnejOdpovede: 1
  panelDialogu: {fileID: 819879652}
  uiText: {fileID: 1818719616}
  tlacidloA: {fileID: 1588957545}
  tlacidloB: {fileID: 1000990110}
